# Copy to .env and fill in. Prisma reads DATABASE_URL from .env (not .env.local).

# Local dev uses SQLite. For production, switch the datasource provider in
# prisma/schema.prisma to "postgresql" and use a Postgres connection string.
DATABASE_URL="file:./dev.db"

# Auth.js v5 session secret — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET="replace-with-a-random-32-byte-base64-string"

# Google Places API key (server-side only) — used by the lead Discover/search.
GOOGLE_MAPS_API_KEY=""

# Stripe billing (optional). Without these, plan switches happen instantly (demo mode).
# When set, paid-plan upgrades go through Stripe Checkout + webhooks.
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
# Public base URL for Checkout success/cancel redirects + email tracking links
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Email outreach (optional). The app picks: Resend -> SMTP -> simulated.
# Open/click tracking + history work in all modes.

# Option A — Resend transactional API (https://resend.com). Best deliverability.
RESEND_API_KEY=""

# Option B — FREE: send through your own Gmail via SMTP (no new service).
#   1. Enable 2-Step Verification on your Google account.
#   2. Create an "App password" (Google Account > Security > App passwords).
#   3. Fill these in (leave RESEND_API_KEY empty to use SMTP):
SMTP_HOST=""            # smtp.gmail.com
SMTP_PORT="587"         # 587 (STARTTLS) or 465 (SSL)
SMTP_USER=""            # your.name@gmail.com
SMTP_PASS=""            # the 16-char app password (not your normal password)

# Sender shown on the email. For Gmail SMTP, use your Gmail address here.
EMAIL_FROM="LeadFinder <onboarding@resend.dev>"

# Follow-up reminder scheduler. A cron hits /api/cron/reminders periodically
# (vercel.json runs it every 5 min on Vercel) to email due reminders. Set a
# secret in production so only the scheduler can trigger it (sent as
# Authorization: Bearer <CRON_SECRET> or ?secret=<CRON_SECRET>).
CRON_SECRET=""

# AI assistant (optional). Without ANTHROPIC_API_KEY the AI buttons are
# disabled. Get a key at console.anthropic.com. AI_MODEL is optional.
ANTHROPIC_API_KEY=""
AI_MODEL="claude-sonnet-4-6"

# "Connect Gmail" — lets each user send outreach from their OWN Gmail (OAuth).
# Create credentials at console.cloud.google.com (see docs/GMAIL-CONNECT.md):
#   APIs & Services > Credentials > OAuth client ID (Web application).
# Authorized redirect URI must be: <NEXT_PUBLIC_APP_URL>/api/google/callback
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
