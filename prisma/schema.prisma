// Prisma schema for LeadFinder CRM.
//
// PORTABILITY: enum-like fields are stored as `String` (validated by Zod / TS
// unions in src/lib/enums.ts) and money as `Decimal`, so this single schema runs
// on SQLite for local dev AND PostgreSQL in production. To go to prod, change the
// datasource `provider` to "postgresql" and set DATABASE_URL — no schema rewrite.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─────────────────────── TENANT & AUTH (Phase 1) ───────────────────────

model Organization {
  id        String   @id @default(cuid())
  name            String
  slug            String   @unique
  monthlyGoal     Int? // monthly revenue target (USD) for the dashboard goal tracker
  customFieldDefs String? // JSON array of {key,label} custom lead fields
  createdAt       DateTime @default(now())

  users          User[]
  pipelines      Pipeline[]
  subscription   Subscription?
  campaigns      Campaign[]
  emailTemplates EmailTemplate[]
  emails         EmailMessage[]
  companies      Company[]
  contacts       Contact[]
  deals          Deal[]
  tags           Tag[]
}

// Outreach campaigns — group leads for coordinated follow-up.
model Campaign {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  description    String   @default("")
  status         String   @default("DRAFT") // DRAFT | RUNNING | COMPLETED
  createdById    String?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  contacts     Contact[]
  emails       EmailMessage[]

  @@index([organizationId])
}

// Reusable email templates ({{name}} placeholders supported).
model EmailTemplate {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  subject        String
  body           String
  type           String   @default("CUSTOM") // INTRODUCTION | FOLLOW_UP | PROPOSAL | CUSTOM
  createdAt      DateTime @default(now())

  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  messages     EmailMessage[]

  @@index([organizationId])
}

// A sent (or simulated) outreach email + its engagement tracking.
model EmailMessage {
  id             String    @id @default(cuid())
  organizationId String
  templateId     String?
  contactId      String?
  campaignId     String?
  fromUserId     String?
  toEmail        String
  subject        String
  body           String
  status         String    @default("SENT") // SENT | OPENED | CLICKED | FAILED | SIMULATED
  trackingId     String    @unique @default(cuid())
  sentAt         DateTime?
  openedAt       DateTime?
  clickedAt      DateTime?
  openCount      Int       @default(0)
  clickCount     Int       @default(0)
  createdAt      DateTime  @default(now())

  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  template     EmailTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  contact      Contact?       @relation(fields: [contactId], references: [id], onDelete: Cascade)
  campaign     Campaign?      @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  fromUser     User?          @relation(fields: [fromUserId], references: [id], onDelete: SetNull)

  @@index([organizationId, status])
  @@index([contactId])
  @@index([campaignId])
}

model User {
  id               String    @id @default(cuid())
  organizationId   String
  email            String    @unique
  passwordHash     String? // null when social-only
  name             String
  avatarUrl        String?
  role             String    @default("SALES_REP") // ADMIN | MANAGER | SALES_REP | VIEWER
  emailVerified    DateTime?
  twoFactorEnabled Boolean   @default(false)
  twoFactorSecret  String?
  createdAt        DateTime  @default(now())

  organization  Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  accounts      Account[]
  tasks         Task[]       @relation("TaskAssignee")
  createdTasks  Task[]       @relation("TaskCreator")
  notifications Notification[]
  sentEmails    EmailMessage[]
  savedViews    SavedView[]
  ownedCompanies Company[] @relation("CompanyOwner")
  ownedContacts  Contact[] @relation("ContactOwner")
  ownedDeals     Deal[]    @relation("DealOwner")

  @@index([organizationId])
}

// Per-user saved filter on the leads list ("smart list").
model SavedView {
  id             String   @id @default(cuid())
  organizationId String
  userId         String
  name           String
  filters        String // JSON: { status?, q? }
  createdAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// In-app notifications (lead assigned, deal won, task assigned, …).
model Notification {
  id             String   @id @default(cuid())
  organizationId String
  userId         String // recipient
  type           String // LEAD_ASSIGNED | DEAL_WON | TASK_ASSIGNED | FOLLOW_UP
  title          String
  body           String   @default("")
  link           String?
  read           Boolean  @default(false)
  createdAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([organizationId])
}

// OAuth provider links (social login — wired in a later phase).
model Account {
  id                String  @id @default(cuid())
  userId            String
  provider          String
  providerAccountId String
  email             String? // connected mailbox address (e.g. the user's Gmail)
  accessToken       String?
  refreshToken      String?
  expiresAt         Int? // epoch seconds when accessToken expires
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

// Email verification + password reset tokens.
model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Pipeline {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  isDefault      Boolean  @default(false)
  createdAt      DateTime @default(now())

  organization Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  stages       PipelineStage[]
  deals        Deal[]

  @@index([organizationId])
}

model PipelineStage {
  id          String @id @default(cuid())
  pipelineId  String
  name        String
  order       Int
  color       String @default("#6366F1")
  probability Int    @default(0) // win probability % at this stage
  kind        String @default("OPEN") // OPEN | WON | LOST (terminal stages)

  pipeline Pipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  deals    Deal[]

  @@index([pipelineId])
}

model Subscription {
  id                   String    @id @default(cuid())
  organizationId       String    @unique
  plan                 String    @default("FREE") // FREE | PRO | AGENCY
  status               String    @default("TRIALING") // TRIALING | ACTIVE | PAST_DUE | CANCELED
  seats                Int       @default(1)
  stripeCustomerId     String?
  stripeSubscriptionId String?
  currentPeriodEnd     DateTime?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

// ─────────────────────── LEGACY LEAD (Phase 2 will org-scope this) ───────────────────────



// Chronological audit trail shown on the lead timeline.
model Activity {
  id             String   @id @default(cuid())
  organizationId String
  type           String // ActivityType (CALL | EMAIL | MEETING | NOTE_ADDED | STAGE_CHANGED | ...)
  userId         String?
  companyId      String?
  contactId      String?
  dealId         String?
  metadata       String? // JSON-encoded extra detail, e.g. {"from":"NEW","to":"CONTACTED"}
  createdAt      DateTime @default(now())

  company Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)
  contact Contact? @relation(fields: [contactId], references: [id], onDelete: Cascade)
  deal    Deal?    @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@index([organizationId, createdAt])
  @@index([contactId])
  @@index([companyId])
  @@index([dealId])
}

// Follow-up tasks: calls, meetings, emails, reminders.
model Task {
  id             String    @id @default(cuid())
  organizationId String
  title          String
  description    String    @default("")
  type           String    @default("CALL") // CALL | MEETING | EMAIL | REMINDER
  status         String    @default("PENDING") // PENDING | IN_PROGRESS | COMPLETED | OVERDUE
  priority       String    @default("MEDIUM") // LOW | MEDIUM | HIGH | URGENT
  dueDate        DateTime?
  completedAt    DateTime?
  remindedAt     DateTime? // set once the due-reminder email has been sent
  assignedUserId String?
  createdById    String?
  companyId      String?
  contactId      String?
  dealId         String?
  createdAt      DateTime  @default(now())

  assignedUser User?    @relation("TaskAssignee", fields: [assignedUserId], references: [id], onDelete: SetNull)
  createdBy    User?    @relation("TaskCreator", fields: [createdById], references: [id], onDelete: SetNull)
  company      Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)
  contact      Contact? @relation(fields: [contactId], references: [id], onDelete: Cascade)
  deal         Deal?    @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@index([organizationId, status])
  @@index([assignedUserId, dueDate])
  @@index([contactId])
  @@index([dealId])
}

// Free-text notes attached to a lead (separate from the legacy single `notes` field).
model Note {
  id             String   @id @default(cuid())
  organizationId String
  body           String
  userId         String?
  companyId      String?
  contactId      String?
  dealId         String?
  createdAt      DateTime @default(now())

  company Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)
  contact Contact? @relation(fields: [contactId], references: [id], onDelete: Cascade)
  deal    Deal?    @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@index([contactId])
  @@index([dealId])
}

// ─────────────────────── CRM v2: relational core ───────────────────────

model Company {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  domain         String?
  website        String?
  phone          String?
  industry       String?
  size           String? // e.g. 1-10, 11-50, 51-200…
  address        String?
  city           String?
  country        String?
  ownerId        String?
  source         String   @default("MANUAL")
  customData     String? // JSON
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  owner        User?        @relation("CompanyOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  contacts     Contact[]
  deals        Deal[]
  activities   Activity[]
  tasks        Task[]
  notes        Note[]
  tagLinks     TagLink[]

  @@index([organizationId])
  @@index([ownerId])
}

model Contact {
  id             String   @id @default(cuid())
  organizationId String
  companyId      String?
  firstName      String
  lastName       String   @default("")
  email          String?
  phone          String?
  title          String? // job title
  ownerId        String?
  campaignId     String?
  source         String   @default("MANUAL")
  lifecycleStage String   @default("LEAD") // LEAD | QUALIFIED | CUSTOMER | EVANGELIST
  leadScore      Int      @default(0)
  emailOptOut    Boolean  @default(false) // unsubscribed (CAN-SPAM/GDPR)
  emailOptOutAt  DateTime?
  customData     String? // JSON
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  company         Company?     @relation(fields: [companyId], references: [id], onDelete: SetNull)
  owner           User?        @relation("ContactOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  campaign        Campaign?    @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  dealLinks       DealContact[]
  primaryForDeals Deal[]       @relation("DealPrimaryContact")
  activities      Activity[]
  tasks           Task[]
  notes           Note[]
  emails          EmailMessage[]
  tagLinks        TagLink[]
  sequenceEnrollments SequenceEnrollment[]

  @@index([organizationId])
  @@index([companyId])
  @@index([ownerId])
  @@index([campaignId])
}

model Deal {
  id                String    @id @default(cuid())
  organizationId    String
  name              String
  value             Decimal?
  currency          String    @default("USD")
  pipelineId        String
  stageId           String
  status            String    @default("OPEN") // OPEN | WON | LOST
  companyId         String?
  primaryContactId  String?
  ownerId           String?
  source            String    @default("MANUAL")
  expectedCloseDate DateTime?
  wonAt             DateTime?
  lostReason        String?
  customData        String? // JSON
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  pipeline       Pipeline      @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  stage          PipelineStage @relation(fields: [stageId], references: [id])
  company        Company?      @relation(fields: [companyId], references: [id], onDelete: SetNull)
  primaryContact Contact?      @relation("DealPrimaryContact", fields: [primaryContactId], references: [id], onDelete: SetNull)
  owner          User?         @relation("DealOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  contactLinks   DealContact[]
  activities     Activity[]
  tasks          Task[]
  notes          Note[]

  @@index([organizationId, status])
  @@index([pipelineId])
  @@index([stageId])
  @@index([companyId])
}

// Many-to-many: a deal can involve several contacts.
model DealContact {
  dealId    String
  contactId String
  role      String? // e.g. Decision maker, Champion

  deal    Deal    @relation(fields: [dealId], references: [id], onDelete: Cascade)
  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@id([dealId, contactId])
  @@index([contactId])
}

model Tag {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  color          String   @default("#64748b")
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  links        TagLink[]

  @@unique([organizationId, name])
}

// Polymorphic tag attachment (a tag can apply to a company or a contact).
model TagLink {
  id        String  @id @default(cuid())
  tagId     String
  companyId String?
  contactId String?

  tag     Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)
  company Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)
  contact Contact? @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([tagId])
  @@index([companyId])
  @@index([contactId])
}

// ─────────────────── Email sequences (cadences) ───────────────────
model Sequence {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  status         String   @default("ACTIVE") // ACTIVE | PAUSED
  createdById    String?
  createdAt      DateTime @default(now())

  steps       SequenceStep[]
  enrollments SequenceEnrollment[]

  @@index([organizationId])
}

model SequenceStep {
  id         String   @id @default(cuid())
  sequenceId String
  order      Int      @default(0)
  dayOffset  Int      @default(0) // days after enrollment to send this step
  subject    String
  body       String
  createdAt  DateTime @default(now())

  sequence Sequence @relation(fields: [sequenceId], references: [id], onDelete: Cascade)

  @@index([sequenceId])
}

model SequenceEnrollment {
  id             String    @id @default(cuid())
  organizationId String
  sequenceId     String
  contactId      String
  enrolledById   String?
  status         String    @default("ACTIVE") // ACTIVE | COMPLETED | STOPPED
  currentStep    Int       @default(0) // index of the next step to send
  nextRunAt      DateTime?
  enrolledAt     DateTime  @default(now())
  stoppedReason  String?

  sequence Sequence @relation(fields: [sequenceId], references: [id], onDelete: Cascade)
  contact  Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([sequenceId, contactId])
  @@index([organizationId, status])
  @@index([nextRunAt])
}
